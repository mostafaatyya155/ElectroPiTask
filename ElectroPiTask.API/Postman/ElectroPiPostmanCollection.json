{
  "info": {
    "name": "ElectroPiTask API",
    "_postman_id": "electropitask-collection-v1",
    "description": "Postman collection for the ElectroPiTask ASP.NET Core 9 Web API.\n\n## Setup\n1. Import this collection.\n2. Set the `baseUrl` variable to your server (default: `https://localhost:5001`).\n3. Run **Login** or **Register** — the `token` variable is set automatically via the test script.\n4. All protected requests will use the token automatically.\n\n## Roles\n- **Admin** — full CRUD on projects and tasks.\n- **Viewer** — read-only (GET endpoints are public).\n\n## Default Admin\n- Email: `admin@elctropi.com`\n- Password: `Admin@123`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:5001",
      "type": "string",
      "description": "Base URL of the ElectroPiTask API"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token — set automatically after Login or Register"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string",
      "description": "Project GUID — set this after creating or retrieving a project"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string",
      "description": "Task GUID — set this after creating or retrieving a task"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — register and login. No token required.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"role\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Register a new user.\n\n**role values:**\n- `0` = Admin\n- `1` = Viewer\n\nThe JWT token is automatically saved to the `token` collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "        console.log('Token saved to collection variable.');",
                  "    }",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has token', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "Register — Success",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"role\": 1\n}"
                }
              },
              "body": "{\n  \"success\": true,\n  \"message\": \"User registered successfully.\",\n  \"data\": {\n    \"token\": \"<jwt_token>\",\n    \"email\": \"jane.doe@example.com\",\n    \"fullName\": \"Jane Doe\",\n    \"firstName\": \"Jane\",\n    \"lastName\": \"Doe\",\n    \"role\": \"Viewer\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/Auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@elctropi.com\",\n  \"password\": \"Admin@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Login with an existing account and receive a JWT token.\n\nThe default seeded admin credentials are:\n- Email: `admin@elctropi.com`\n- Password: `Admin@123`\n\nThe JWT token is automatically saved to the `token` collection variable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (json.data && json.data.token) {",
                  "        pm.collectionVariables.set('token', json.data.token);",
                  "        console.log('Token saved to collection variable.');",
                  "    }",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has token', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('token');",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "Login — Success",
              "status": "OK",
              "code": 200,
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@elctropi.com\",\n  \"password\": \"Admin@123\"\n}"
                }
              },
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"data\": {\n    \"token\": \"<jwt_token>\",\n    \"email\": \"admin@elctropi.com\",\n    \"fullName\": \"Default User\",\n    \"firstName\": \"Default\",\n    \"lastName\": \"User\",\n    \"role\": \"Admin\"\n  }\n}"
            },
            {
              "name": "Login — Invalid Credentials",
              "status": "Bad Request",
              "code": 400,
              "originalRequest": {
                "method": "POST",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"wrong@example.com\",\n  \"password\": \"wrongpassword\"\n}"
                }
              },
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid email or password\",\n  \"data\": null\n}"
            }
          ]
        }
      ]
    },
    {
